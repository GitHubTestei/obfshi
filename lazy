UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.LeftControl then
        MainFrame.Visible = not MainFrame.Visible
        TweenService:Create(Trigger, TweenInfo.new(0.3), { Rotation = MainFrame.Visible and 45 or 0 }):Play()
        return
    end

    if bindingFor then
        local name = bindingFor
        bindingFor = nil
        if input.KeyCode ~= Enum.KeyCode.Escape then
            Keybinds[name] = input.KeyCode
            keybindButtons[name].button.Text = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
        else
            keybindButtons[name].button.Text = Keybinds[name] and tostring(Keybinds[name]):gsub("Enum.KeyCode.", "") or "BIND"
        end
        keybindButtons[name].button.TextColor3 = Color3.new(1, 1, 1)
        return
    end

    for name, key in pairs(Keybinds) do
        if key and input.KeyCode == key then
            if name == "Reset" then
                FireReset(indRefs[name])
            else
                ToggleFeature(name, indRefs[name])
            end
        end
    end
end)

