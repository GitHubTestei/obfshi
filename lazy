local animPath   = ReplicatedStorage:WaitForChild("OldControllers", 8):WaitForChild("CombatClient", 5):WaitForChild("Animations", 5)
local rightPunch = animPath:WaitForChild("Right Punch", 5)
local leftPunch  = animPath:WaitForChild("Left Punch", 5)

local ANIM_DELAY   = 0.1
local lastAnimTime = 0

local function PlayKillAuraAnim()
    local now = os.clock()
    if now - lastAnimTime < ANIM_DELAY then return end
    lastAnimTime = now

    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local anim = hum and hum:FindFirstChildOfClass("Animator")
    if not anim then return end

    local punch = (math.random(1, 2) == 1) and rightPunch or leftPunch
    pcall(function()
        local track = anim:LoadAnimation(punch)
        track:Play()
    end)
end

local friendHighlights = {}
local targetHighlights = {}
local currentTargetHighlight = nil

local function UpdateVisuals(currentTarget)
    local pulse = 0.4 + ((math.sin(tick() * 10) + 1) / 2 * 0.3)

    if currentTarget and Features.KillAura then
        if not currentTargetHighlight or currentTargetHighlight.Adornee ~= currentTarget then
            if currentTargetHighlight then currentTargetHighlight:Destroy() end
            currentTargetHighlight = Instance.new("Highlight")
            currentTargetHighlight.FillColor = getAccent()
            currentTargetHighlight.OutlineColor = Color3.new(1,1,1)
            currentTargetHighlight.Adornee = currentTarget
            currentTargetHighlight.Parent = currentTarget
        end
        currentTargetHighlight.FillColor = getAccent()
        currentTargetHighlight.FillTransparency = pulse
    elseif currentTargetHighlight then
        currentTargetHighlight:Destroy()
        currentTargetHighlight = nil
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and IsWhitelisted(plr) and plr.Character then
            if not friendHighlights[plr] or friendHighlights[plr].Adornee ~= plr.Character then
                if friendHighlights[plr] then friendHighlights[plr]:Destroy() end
                local h = Instance.new("Highlight")
                h.FillColor = FRIEND_COLOR
                h.OutlineColor = Color3.new(1,1,1)
                h.Adornee = plr.Character
                h.Parent = plr.Character
                friendHighlights[plr] = h
            end
            friendHighlights[plr].FillTransparency = pulse
        elseif friendHighlights[plr] then
            friendHighlights[plr]:Destroy()
            friendHighlights[plr] = nil
        end
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and IsTargeted(plr) and plr.Character then
            if not targetHighlights[plr] or targetHighlights[plr].Adornee ~= plr.Character then
                if targetHighlights[plr] then targetHighlights[plr]:Destroy() end
                local h = Instance.new("Highlight")
                h.FillColor = TARGET_COLOR
                h.OutlineColor = Color3.new(0,0,0)
                h.Adornee = plr.Character
                h.Parent = plr.Character
                targetHighlights[plr] = h
            end
            targetHighlights[plr].FillTransparency = pulse
        elseif targetHighlights[plr] then
            targetHighlights[plr]:Destroy()
            targetHighlights[plr] = nil
        end
    end
end

