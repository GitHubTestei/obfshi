RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    if Features.AutoBlock then pcall(BlockRF.InvokeServer, BlockRF, true) end
    local currentTarget = nil
    if Features.KillAura then
        local closest, dist = nil, 16
        local targetsActive = HasTargets()
        for _, p in Players:GetPlayers() do
            if p == LocalPlayer or IsWhitelisted(p) then continue end
            if targetsActive and not IsTargeted(p) then continue end
            local c = p.Character
            if c and c:FindFirstChild("HumanoidRootPart") and c:FindFirstChild("Humanoid") and c.Humanoid.Health > 0 then
                local d = (c.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if d < dist then dist = d; closest = c end
            end
        end
        if closest then
            currentTarget = closest
            pcall(HitRF.InvokeServer, HitRF, closest.Humanoid, char.HumanoidRootPart.Position)
            if Features["- KillAura Anims"] then
                PlayKillAuraAnim()
            end
        end
    end
    UpdateVisuals(currentTarget)
end)

