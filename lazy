--  HIDDEN (DESYNC)
-- ────────────────────────────────────────────────
local desyncT = { enabled = false, loc = CFrame.new() }
local customDesyncEnabled = true

-- Variables for the 0.5s delay
local lastExtraClipToggleTime = 0
local extraClipActive = false

local TextBoxX = { Text = "0" }
local TextBoxY = { Text = "-10" }
local TextBoxZ = { Text = "0" }

local function getOffsetCFrame()
    local baseY
    if customDesyncEnabled then
        baseY = tonumber(TextBoxY.Text) or -10
    else
        local ping = LocalPlayer:GetNetworkPing() * 1000
        if ping < 100 then baseY = 0
        elseif ping <= 170 then baseY = 0
        else baseY = 0 end
    end

    local x = customDesyncEnabled and (tonumber(TextBoxX.Text) or 0) or 0
    local z
    if customDesyncEnabled then
        z = tonumber(TextBoxZ.Text) or 0
    else
        local ping = LocalPlayer:GetNetworkPing() * 1000
        if ping < 100 then z = -2
        elseif ping <= 170 then z = -2.7
        else z = -3.7 end
    end

    return CFrame.new(x, baseY, z)
end

local desynchook = nil
local hookOk, hookErr = pcall(function()
    desynchook = hookmetamethod(game, "__index", newcclosure(function(self, key)
        if desyncT.enabled and not checkcaller() and
           key == "CFrame" and
           LocalPlayer.Character and
           self == LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            return desyncT.loc
        end
        if desynchook then
            return desynchook(self, key)
        end
        return (rawget(getrawmetatable(game), "__index"))(self, key)
    end))
end)
if not hookOk then
    warn("Hidden hook failed (may not affect other features):", hookErr)
end

RunService.Heartbeat:Connect(function()
    local character = LocalPlayer.Character
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end

    if not Features.Hidden then
        humanoid.CameraOffset = Vector3.new(0, 0, 0)
        extraClipActive = false
        return
    end

    -- Toggle Logic: Detect when Extra Clip is turned ON
    if Features["- Extra Clip"] then
        if not extraClipActive then
            extraClipActive = true
            lastExtraClipToggleTime = tick() -- Start the 0.5s timer
        end
    else
        extraClipActive = false
    end

    -- Check if the 0.5s delay has passed
    local isDelayOver = (tick() - lastExtraClipToggleTime) >= 0.2
    local currentlyUsingExtra = Features["- Extra Clip"] and isDelayOver

    desyncT.loc = root.CFrame
    local offset = getOffsetCFrame()

    local extraY = currentlyUsingExtra and -10 or 0
    local camOffsetY = currentlyUsingExtra and 20 or 10

    root.CFrame = desyncT.loc * offset * CFrame.new(0, extraY, 0)
    humanoid.CameraOffset = Vector3.new(0, camOffsetY, 0)

    RunService.RenderStepped:Wait()

    root.CFrame = desyncT.loc
end)

