-- ────────────────────────────────────────────────
--  FRIEND / TARGET CHECK
-- ────────────────────────────────────────────────
local function IsWhitelisted(plr)
    if Features.Friends == "" then return false end
    local names = string.split(string.lower(Features.Friends), " ")
    local targetUser = string.lower(plr.Name)
    local targetDisplay = string.lower(plr.DisplayName)
    for _, name in pairs(names) do
        if name ~= "" and (targetUser:find(name) or targetDisplay:find(name)) then
            return true
        end
    end
    return false
end

local function IsTargeted(plr)
    if Features.Targets == "" then return false end
    local names = string.split(string.lower(Features.Targets), " ")
    local targetUser = string.lower(plr.Name)
    local targetDisplay = string.lower(plr.DisplayName)
    for _, name in pairs(names) do
        if name ~= "" and (targetUser:find(name) or targetDisplay:find(name)) then
            return true
        end
    end
    return false
end

local function HasTargets()
    if Features.Targets == "" then return false end
    for _, name in pairs(string.split(Features.Targets, " ")) do
        if name ~= "" then return true end
    end
    return false
end

