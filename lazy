local activeNotif = nil
local activeNotifConn = nil
local activeNotifLabel = nil
local activeNotifTask = nil

local function dismissNotif(notif, conn)
    if activeNotif == notif then activeNotif = nil activeNotifLabel = nil end
    if activeNotifConn == conn then activeNotifConn = nil end
    TweenService:Create(notif, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = UDim2.new(0.5, -110, 0, -40)
    }):Play()
    task.delay(0.2, function()
        if notif and notif.Parent then notif:Destroy() end
        if conn then conn:Disconnect() end
    end)
end

local function showNotif(text)
    if activeNotif and activeNotif.Parent then
        activeNotifLabel.Text = text
        if activeNotifTask then task.cancel(activeNotifTask) end
        TweenService:Create(activeNotif, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.5, -110, 0, 12)
        }):Play()
        activeNotifTask = task.delay(1.0, function()
            if activeNotif and activeNotif.Parent then dismissNotif(activeNotif, activeNotifConn) end
        end)
        return
    end

    local notif = Instance.new("Frame", sg)
    notif.Size = UDim2.new(0, 220, 0, 36)
    notif.Position = UDim2.new(0.5, -110, 0, -40)
    notif.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
    notif.BorderSizePixel = 0
    notif.ZIndex = 2147483647
    Instance.new("UICorner", notif)

    local notifStroke = Instance.new("UIStroke", notif)
    notifStroke.Thickness = 1.5

    local label = Instance.new("TextLabel", notif)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 12
    label.ZIndex = 2147483647

    activeNotif = notif
    activeNotifLabel = label

    local phase = 0
    local conn = RunService.RenderStepped:Connect(function(dt)
        phase = (phase + dt * 1.5) % (math.pi * 2)
        local brightness = 0.4 + (math.sin(phase) + 1) / 2 * 0.6
        notifStroke.Color = Color3.fromHSV(rainbowPhase, 1, brightness)
    end)
    activeNotifConn = conn

    TweenService:Create(notif, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, -110, 0, 12)
    }):Play()

    activeNotifTask = task.delay(1.0, function()
        if notif and notif.Parent then dismissNotif(notif, conn) end
    end)
end

